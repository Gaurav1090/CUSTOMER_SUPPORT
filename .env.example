APP_API_KEY=replace-with-a-long-random-value
GROQ_API_KEY=replace-with-your-groq-key
ALLOWED_ORIGINS=https://yourdomain.com

# Chroma storage. Leave CHROMA_STORAGE_MODE unset (or "auto"): if
# CHROMA_API_KEY/TENANT/DATABASE below are filled in, Chroma Cloud is used
# ALWAYS -- there is no silent fallback to a local store once cloud is
# configured. Only if these three are left blank does it fall back to a
# local chroma_db/ folder for pure offline dev, and it logs loudly when it
# does. Get a free Chroma Cloud account at trychroma.com if you don't have
# one yet -- there is no local emulator for it.
CHROMA_STORAGE_MODE=
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

# Ingestion landing storage. Local dev: a folder on disk (created for you).
# Prod: point this at gs://bucket/landing, s3://bucket/landing, or
# abfs://container/landing -- same code, no changes needed, just install
# the matching fsspec backend (see requirements-optional.txt).
LANDING_PATH=data/landing
INDEX_PATH=data/landing/_index
# Set true only to also (re)ingest the bundled demo CSV alongside PDFs.
INGEST_LEGACY_CSV=false

# Optional Redis cache/rate-limit backend
REDIS_URL=
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_ENTRIES=500
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# Optional Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
