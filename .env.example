APP_API_KEY=replace-with-a-long-random-value
GROQ_API_KEY=replace-with-your-groq-key
ALLOWED_ORIGINS=https://yourdomain.com

# Required when llm.provider is "huggingface" in config.yaml (a free,
# no-billing-account stopgap using HF's serverless Inference API). Get a
# plain access token (not a billed Inference Endpoint) at
# huggingface.co/settings/tokens -- "Read" scope is enough.
HF_TOKEN=

# Required when embedding_model.provider or llm.provider is "google".
GOOGLE_API_KEY=

# Optional Cohere Rerank for semantic reranking of retrieved candidates.
# Leave blank to fall back to lexical term-overlap reranking (logged loudly
# as a warning on every query so degraded mode is never silent). Get a key
# at dashboard.cohere.com.
COHERE_API_KEY=

# Chroma storage. Leave CHROMA_STORAGE_MODE unset (or "auto"): if
# CHROMA_API_KEY/TENANT/DATABASE below are filled in, Chroma Cloud is used
# ALWAYS -- there is no silent fallback to a local store once cloud is
# configured. Only if these three are left blank does it fall back to a
# local chroma_db/ folder for pure offline dev, and it logs loudly when it
# does. Get a free Chroma Cloud account at trychroma.com if you don't have
# one yet -- there is no local emulator for it.
CHROMA_STORAGE_MODE=
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=

# Ingestion landing storage. Local dev: a folder on disk (created for you).
# Prod: point this at gs://bucket/landing, s3://bucket/landing, or
# abfs://container/landing -- same code, no changes needed, just install
# the matching fsspec backend (see requirements-optional.txt).
LANDING_PATH=data/landing
INDEX_PATH=data/landing/_index
# Set true only to also (re)ingest the bundled demo CSV alongside PDFs.
INGEST_LEGACY_CSV=false

# Optional Redis backend for response cache, rate limiting, AND session
# (chat history) storage -- all three fall back to in-memory when unset,
# which only works correctly for a single instance/process: in-memory
# session history in particular means multi-turn conversations only work
# as long as the same replica keeps handling that session. Memorystore
# instances etc. are typically VPC-private -- reachable from services
# running inside that VPC (e.g. GKE), not from arbitrary local dev
# machines.
REDIS_URL=
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
SEMANTIC_CACHE_THRESHOLD=0.92
SEMANTIC_CACHE_MAX_ENTRIES=500
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
# How long a session's chat history is kept, and how many turns are stored
# per session before older ones are trimmed off (only the last 4 are ever
# used to build the prompt, per main.py:_build_chat_history).
SESSION_TTL_SECONDS=86400
SESSION_MAX_TURNS=20

# Optional Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
